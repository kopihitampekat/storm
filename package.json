{
  "name": "storm-scan",
  "version": "0.1.0",
  "description": "Distributed serverless scanning framework",
  "type": "module",
  "bin": {
    "storm": "./bin/storm.ts"
  },
  "scripts": {
    "dev": "tsx bin/storm.ts",
    "build": "tsup src/cli/index.ts --format esm --dts --outDir dist/cli",
    "build:worker:cf": "esbuild src/worker/adapters/cloudflare.ts --bundle --outfile=dist/workers/cloudflare.js --format=esm --target=es2022",
    "build:worker:vercel": "esbuild src/worker/adapters/vercel.ts --bundle --outfile=dist/workers/vercel.js --format=esm --target=es2022",
    "build:worker:fly": "esbuild src/worker/adapters/fly.ts --bundle --outfile=dist/workers/fly.js --format=esm --target=es2022",
    "lint": "eslint src/",
    "test": "vitest"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.0",
    "cli-table3": "^0.6.5",
    "p-limit": "^6.1.0",
    "p-retry": "^6.2.0",
    "zod": "^3.23.0",
    "fast-glob": "^3.3.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsx": "^4.19.0",
    "tsup": "^8.2.0",
    "esbuild": "^0.23.0",
    "vitest": "^2.0.0",
    "@cloudflare/workers-types": "^4.20240806.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
