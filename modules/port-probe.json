{
  "name": "port-probe",
  "description": "Probe common HTTP/HTTPS ports on targets via fetch",
  "scanner": "port-probe",
  "options": {
    "timeout": 3000,
    "ports": [80, 443, 8080, 8443, 8000, 8888, 3000, 5000, 9090, 9443, 4443, 8181, 9000, 10000],
    "userAgent": "Mozilla/5.0 (compatible; Storm/1.0)"
  },
  "output": {
    "format": "jsonl",
    "fields": ["target", "host", "openPorts", "totalScanned", "totalOpen"]
  },
  "concurrency": {
    "targetsPerWorker": 10,
    "maxConcurrentPerWorker": 5
  }
}
